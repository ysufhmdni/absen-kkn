generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id          String       @id @default(cuid())
  nim         String       @unique
  name        String
  divisi      String?
  role        Role         @default(USER)
  prodi       String?
  attendances Attendance[]
}

model Attendance {
  id         String   @id @default(cuid())
  userId     String
  date       DateTime @db.Date
  session    Session
  status     Status   @default(hadir)
  keterangan String?  @db.Text
  checkInAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, date, session], name: "userId_date_session", map: "userId_date_session")
}

model absensi {
  id          Int                 @id @default(autoincrement())
  nim         String              @db.VarChar(20)
  tanggal     DateTime            @db.Date
  jenis_absen absensi_jenis_absen
  jam_absen   DateTime            @db.Time(0)
  latitude    Decimal?            @db.Decimal(10, 8)
  longitude   Decimal?            @db.Decimal(11, 8)
  status      absensi_status?     @default(hadir)
  mahasiswa   mahasiswa           @relation(fields: [nim], references: [nim], onDelete: Cascade, map: "fk_absensi_nim")

  @@index([nim], map: "fk_absensi_nim")
}

model mahasiswa {
  nim     String         @id @db.VarChar(20)
  nama    String         @db.VarChar(100)
  prodi   String?        @db.VarChar(100)
  divisi  String?        @db.VarChar(100)
  role    mahasiswa_role @default(mahasiswa)
  absensi absensi[]
}

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

enum Session {
  PAGI
  MALAM
}

enum Status {
  hadir
  izin
  alpha
}

enum absensi_jenis_absen {
  pagi
  malam
}

enum mahasiswa_role {
  mahasiswa
  admin
  super_admin
}

enum absensi_status {
  hadir
  terlambat
}